{
  "name": "wa-ai-assistant",
  "version": "1.0.0",
  "description": "AI Personal Assistant for WhatsApp — built with Baileys, Fastify, Prisma, and OpenRouter",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "keywords": ["whatsapp", "ai", "assistant", "chatbot", "baileys"],
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "@prisma/client": "^6.9.0",
    "fastify": "^5.3.3",
    "zod": "^3.25.67",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "node-cron": "^3.0.3",
    "chrono-node": "^2.7.7",
    "mathjs": "^14.5.2",
    "tesseract.js": "^6.0.1",
    "pdf-parse": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "undici": "^7.10.0",
    "mime-types": "^3.0.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "prisma": "^6.9.0",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/mime-types": "^2.1.4"
  }
}
