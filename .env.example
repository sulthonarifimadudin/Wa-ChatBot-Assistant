# ============================================
# WhatsApp AI Assistant — Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wa_assistant

# === OpenRouter Configuration ===
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free

# === Groq Configuration (Untuk Voice Note) ===
# Dapatkan gratis di https://console.groq.com/keys
GROQ_API_KEY=gsk_...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# WhatsApp
WA_SESSION_NAME=wa-assistant

# Media Storage
MEDIA_DIR=./media

# Scheduler
REMINDER_CHECK_INTERVAL_SECONDS=30
